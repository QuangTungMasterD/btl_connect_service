# Service
SERVICE_NAME=notification-service
SERVICE_VERSION=1.0.0
AUTH_TOKEN=local-dev-token

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_QUEUE=notification.alerts
RABBITMQ_EXCHANGE=amq.topic
RABBITMQ_ROUTING_KEY=notification.alerts

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=notify_user
POSTGRES_PASSWORD=notify_pass
POSTGRES_DB=notification_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your app password
SMTP_FROM=notifications@campus.edu

# # SMS (Twilio) - optional
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Display (WebSocket)
WEBSOCKET_URL=ws://localhost:8080/

# Retry
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2

# Telegram
TELEGRAM_BOT_TOKEN=your telebot token
TELEGRAM_CHAT_ID=your tele chat id with chat
